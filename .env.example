# ── KOL Tracker Configuration ─────────────────────────────────────────────────

# X (Twitter) API v2 — pay-per-use (~$0.01 per 50 tweets)
# Get credentials at: https://developer.twitter.com/en/portal/dashboard
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=

# Enable KOL listening
KOL_ENABLED=true

# Server port
PORT=3002

# Telegram alerts (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
